# =====================================================
# AQI Forecaster — Environment Configuration
# Copy this to .env and fill in your values
# =====================================================

# Flask
FLASK_DEBUG=True
FLASK_ENV=development
SECRET_KEY=change-this-to-a-secure-random-string
PORT=5005

# MySQL Database
# Change user/password/host/port as per your MySQL setup
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/aqi_forecaster
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aqi_forecaster
DB_USER=root
DB_PASSWORD=password

# External APIs (optional — app works without these using simulated data)
# OPENWEATHER_API_KEY=your_openweathermap_api_key
# NEWSAPI_KEY=your_newsapi_key
# IQAIR_API_KEY=your_iqair_api_key
# CPCB_API_KEY=your_cpcb_api_key
